{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "windmill",
  "homepage": "https://github.com/gowindmill/go-windmill",
  "items": [
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "cn() utility",
      "description": "clsx + extended tailwind-merge, aware of Windmill's custom font sizes and token colors.",
      "dependencies": [
        "clsx",
        "tailwind-merge"
      ],
      "files": [
        {
          "path": "lib/utils.ts",
          "type": "registry:lib"
        }
      ]
    },
    {
      "name": "windmill-tokens",
      "type": "registry:style",
      "title": "Windmill tokens",
      "description": "Design tokens resolved from WINDMILL_LIGHT_THEME_V3 plus the Tailwind config. Install once as the base style.",
      "registryDependencies": [
        "utils"
      ],
      "files": [
        {
          "path": "app/globals.css",
          "type": "registry:file",
          "target": "app/globals.css"
        },
        {
          "path": "tailwind.config.ts",
          "type": "registry:file",
          "target": "tailwind.config.ts"
        }
      ]
    },
